# Copy to .env and edit (make env does this and fills JKRT_SESSION_SECRET).
# Never commit .env. The server does not load .env by itself — use:
#   make run-auth
# or: set -a && source .env && set +a && go run ./cmd/server

# Listen address. Use loopback when tunneling so only cloudflared can reach the app.
# For pure local browser use, :8080 is also fine.
JKRT_ADDR=127.0.0.1:8080

# SQLite path (gitignored)
JKRT_DB_PATH=./jkrt.db

# Auth: on (default) requires password + session secret before public use.
# Use off only for local development. NEVER JKRT_AUTH=off with Cloudflare Tunnel
# or any public hostname — see docs/auth-and-tunnel.md.
JKRT_AUTH=on

# Bootstrap password for user id=1 when no user row exists (required if auth on and empty DB).
# Does not rotate an existing password — use: make setpassword
# or: go run ./cmd/setpassword -db ./jkrt.db
JKRT_PASSWORD=change-me

# HMAC session secret, at least 32 bytes of random data (required if auth on).
# Changing this invalidates all existing sessions on restart.
# Generate: openssl rand -hex 32   or: make secret
JKRT_SESSION_SECRET=replace-with-32-plus-random-bytes

# Session cookie TTL (Go duration). Default 168h = 7 days.
# Cookie flags: HttpOnly, SameSite=Lax; Secure when HTTPS / X-Forwarded-Proto=https.
JKRT_SESSION_TTL=168h

# NHK main RSS override (optional). Other publishers (Yahoo topics, ITmedia, BBC Japanese)
# are hardcoded in internal/scrape.DefaultSources — see README.
# JKRT_NHK_MAIN_RSS_URL=https://news.web.nhk/n-data/conf/na/rss/cat0.xml

# JLPT N2+ extract filter: classify Words missing from the embed map via Grok Build headless.
# auto (default) = on when `grok` is on PATH; off = map-only (unlisted skip).
# JKRT_JLPT_CLASSIFY=auto
# JKRT_JLPT_CLASSIFY_MODEL=composer-2.5
# JKRT_JLPT_CLASSIFY_TIMEOUT=12s
# JKRT_JLPT_CLASSIFY_MAX_PER_EXTRACT=10
